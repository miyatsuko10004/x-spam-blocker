# X (Twitter) Spam Auto Blocker Settings

# Xのユーザーデータディレクトリ（Chrome/Edge等のログインセッション情報が含まれるパス）
# 例: /Users/username/Library/Application Support/Google/Chrome/Default
# または空欄にして、Playwright独自のディレクトリ（毎回ログインが必要）を利用することも可能です。
USER_DATA_DIR=""

# ドライランモード（trueの場合、ログ出力のみで実際のブロックは行いません）
DRY_RUN=true

# 1回のリスクスキャンでの最大ブロック件数
MAX_BLOCKS_PER_RUN=50

# 待機時間設定 (ミリ秒)
# ブロック処理ごとのディレイをランダム化するための範囲
MIN_DELAY_MS=5000
MAX_DELAY_MS=15000

# スパム判定基準
# 1. 検出するキーワード（カンマ区切り、部分一致、大文字小文字無視）
SPAM_KEYWORDS="副業,オナ,プロフ見て,稼げる,裏アカ,固定ツイ,アフィリエイト,バイナリー,配り"

# 2. スパムと見なす最大フォロワー数（これ以下のフォロワー数ならスパム候補、-1で無効）
MAX_FOLLOWER_COUNT=15

# 3. 最新ポスト（ツイート）に対するスパムキーワード（カンマ区切り、部分一致、大文字小文字無視）
SPAM_TWEET_KEYWORDS="銘柄情報を希望,資料をまとめました,ご希望の方はDM"
